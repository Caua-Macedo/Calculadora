<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    tools:context=".MainActivity">

    <!-- Display principal -->
    <EditText
        android:id="@+id/edtNum"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:text=""
        android:hint="0"
        android:textColor="#FFFFFF"
        android:textSize="110sp"
        android:textStyle="bold"
        android:gravity="end|center_vertical"
        android:background="#1A1A1A"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:focusable="false"
        android:ellipsize="start"
        android:maxLines="1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Resultado -->
    <TextView
        android:id="@+id/textViewRes"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:text=""
        android:textColor="#FF6B35"
        android:textSize="18sp"
        android:gravity="end|center_vertical"
        android:paddingEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/edtNum"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Linha separadora -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="5dp"
        android:background="#FF6B35"
        app:layout_constraintTop_toBottomOf="@id/textViewRes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!--
        [ 7 ] [ 8 ] [ 9 ] [ ÷ ]
        [ 4 ] [ 5 ] [ 6 ] [ × ]
        [ 1 ] [ 2 ] [ 3 ] [ − ]
        [CE ] [ 0 ] [ = ] [ + ]
    -->

    <!-- LINHA 1: 7, 8, 9, ÷ -->
    <Button
        android:id="@+id/btn7"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="7"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn8"
        app:layout_constraintBottom_toTopOf="@id/btn4"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn8"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="8"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toEndOf="@id/btn7"
        app:layout_constraintEnd_toStartOf="@id/btn9"
        app:layout_constraintBottom_toTopOf="@id/btn5"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn9"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="9"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toEndOf="@id/btn8"
        app:layout_constraintEnd_toStartOf="@id/btnDiv"
        app:layout_constraintBottom_toTopOf="@id/btn6"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnDiv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="÷"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#2D1A0E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toEndOf="@id/btn9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnMult"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"/>

    <!-- LINHA 2: 4, 5, 6, × -->
    <Button
        android:id="@+id/btn4"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="4"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn5"
        app:layout_constraintBottom_toTopOf="@id/btn1"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn5"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="5"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn8"
        app:layout_constraintStart_toEndOf="@id/btn4"
        app:layout_constraintEnd_toStartOf="@id/btn6"
        app:layout_constraintBottom_toTopOf="@id/btn2"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn6"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="6"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn9"
        app:layout_constraintStart_toEndOf="@id/btn5"
        app:layout_constraintEnd_toStartOf="@id/btnMult"
        app:layout_constraintBottom_toTopOf="@id/btn3"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnMult"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="×"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#2D1A0E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btnDiv"
        app:layout_constraintStart_toEndOf="@id/btn6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSub"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <!-- LINHA 3: 1, 2, 3, − -->
    <Button
        android:id="@+id/btn1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="1"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn2"
        app:layout_constraintBottom_toTopOf="@id/btnCE"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="2"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn5"
        app:layout_constraintStart_toEndOf="@id/btn1"
        app:layout_constraintEnd_toStartOf="@id/btn3"
        app:layout_constraintBottom_toTopOf="@id/btn0"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btn3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="3"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn6"
        app:layout_constraintStart_toEndOf="@id/btn2"
        app:layout_constraintEnd_toStartOf="@id/btnSub"
        app:layout_constraintBottom_toTopOf="@id/btnIgual"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <Button
        android:id="@+id/btnSub"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="−"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#2D1A0E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btnMult"
        app:layout_constraintStart_toEndOf="@id/btn3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSoma"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"/>

    <!-- LINHA 4: CE, 0, =, + -->
    <Button
        android:id="@+id/btnCE"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="CE"
        android:textSize="15sp"
        android:textColor="#FF6B35"
        android:textStyle="bold"
        android:backgroundTint="#2D1A0E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn0"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn0"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="0"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2A2A2A"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn2"
        app:layout_constraintStart_toEndOf="@id/btnCE"
        app:layout_constraintEnd_toStartOf="@id/btnIgual"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnIgual"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="="
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#FF6B35"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btn3"
        app:layout_constraintStart_toEndOf="@id/btn0"
        app:layout_constraintEnd_toStartOf="@id/btnSoma"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSoma"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="+"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#2D1A0E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btnSub"
        app:layout_constraintStart_toEndOf="@id/btnIgual"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>